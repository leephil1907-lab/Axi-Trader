# Database
DATABASE_URL="postgresql://user:password@localhost:5432/axi_trader?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Admin credentials
ADMIN_EMAIL="admin@axi.com"
ADMIN_PASSWORD="admin123"

# Stripe (for real payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Crypto payments (for real crypto deposits)
CRYPTO_API_KEY="your-crypto-api-key"

# Broker API (for real order execution)
BROKER_API_URL="https://api.broker.com"
BROKER_API_KEY="your-broker-api-key"
BROKER_API_SECRET="your-broker-api-secret"

# KYC Provider (SumSub, Onfido, etc.)
KYC_PROVIDER="sumsub"
KYC_API_KEY="your-kyc-api-key"
KYC_SECRET_KEY="your-kyc-secret"

# WebSocket (for live prices)
WS_PORT=3001

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_URL="http://localhost:3000/api"
