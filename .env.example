# ============================================================
# AXI TRADER - Environment Variables
# ============================================================

# Database
# For SQLite (development): file:./dev.db
# For PostgreSQL (production): postgresql://user:password@host:5432/axi_trader?schema=public
DATABASE_URL="file:./dev.db"

# JWT Secret (MUST be 32+ characters in production!)
JWT_SECRET="axi-trader-super-secret-jwt-key-change-in-production-32chars"
JWT_EXPIRES_IN="7d"

# Admin credentials (for seed script)
ADMIN_EMAIL="admin@axi.com"
ADMIN_PASSWORD="admin123"

# Stripe (for real payments - optional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Crypto payments (optional)
CRYPTO_API_KEY="your-crypto-api-key"

# Broker API (optional)
BROKER_API_URL="https://api.broker.com"
BROKER_API_KEY="your-broker-api-key"
BROKER_API_SECRET="your-broker-api-secret"

# KYC Provider (optional)
KYC_PROVIDER="sumsub"
KYC_API_KEY="your-kyc-api-key"
KYC_SECRET_KEY="your-kyc-secret"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_URL="http://localhost:3000/api"

# WebSocket (optional)
WS_PORT=3001
