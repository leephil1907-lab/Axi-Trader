generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String?
  name        String
  firstName   String?
  lastName    String?
  phone       String?
  country     String?
  language    String   @default("en")
  currency    String   @default("USD")
  accountType String   @default("standard")
  platform    String   @default("mt5")
  role        String   @default("user")
  status      String   @default("active")
  kycStatus   String   @default("not_started")
  balance     Float    @default(0)
  equity      Float    @default(0)
  margin      Float    @default(0)
  freeMargin  Float    @default(0)
  marginLevel Float    @default(0)
  totalProfit Float    @default(0)
  totalLoss   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLogin   DateTime?

  transactions Transaction[]
  trades       Trade[]
  kycDocs      KycDocument[]
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  type            String
  amount          Float
  currency        String
  method          String
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?
}

model Trade {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  symbol       String
  type         String
  volume       Float
  openPrice    Float
  currentPrice Float
  profit       Float
  stopLoss     Float?
  takeProfit   Float?
  openedAt     DateTime @default(now())
  closedAt     DateTime?
}

model KycDocument {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  type            String
  status          String   @default("pending")
  fileUrl         String
  fileName        String
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?
}
